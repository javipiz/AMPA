// -------------------------------
// DATASOURCE / GENERATOR
// -------------------------------
datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}


// -------------------------------
// MODELS
// -------------------------------

// 👤 Usuario para login y panel
model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  name      String
  role      String    // SUPERADMIN | ADMIN | USER
  password  String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


// 👪 Familia
model Family {
  id               Int      @id @default(autoincrement())
  membershipNumber String?  @unique
  familyName       String
  address          String
  phone            String
  email            String
  joinDate         String
  status           String   // "Activo" | "Baja"

  aiSummary String?
  createdBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members   Member[]
}


// 👧🧒 Miembros de la familia
model Member {
  id        Int    @id @default(autoincrement())
  firstName String
  lastName  String
  birthDate String
  role      String     // Padre | Madre | Hijo/a | Tutor
  gender    String?
  notes     String?
  email     String?
  phone     String?

  familyId  Int
  family    Family @relation(fields: [familyId], references: [id])
}
